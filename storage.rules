rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Allow user to read and create/update their own documents, but not delete.
    match /userDocs/{userId}/{allPaths=**} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }
    
    // Allow user to write their own permission attachments. Any authenticated user can read.
    match /permission-attachments/{userId}/{permissionId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow admin to upload and public read for ecosystem logos
    match /ecosystem_logos/{allPaths=**} {
        allow read;
        allow write: if request.auth != null && (
            exists(/databases/(default)/documents/roles_admin/$(request.auth.uid)) ||
            exists(/databases/(default)/documents/roles_hrd/$(request.auth.uid))
        );
    }
    
    // Allow admin to upload images for dynamic ecosystem sections
    match /ecosystem_sections/{sectionId}/{fileName} {
      allow read;
      allow write: if request.auth != null && (
          exists(/databases/(default)/documents/roles_admin/$(request.auth.uid)) ||
          exists(/databases/(default)/documents/roles_hrd/$(request.auth.uid))
      );
    }
    
    // Rules for job-related files
    match /jobs/{jobId}/{allPaths=**} {
      // Allow public read for job cover images
      allow read;
      
      allow write: if request.auth != null && (
        exists(/databases/(default)/documents/roles_admin/$(request.auth.uid)) ||
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'hrd'
      );
    }

    // Rules for professional offering templates (master reference PDFs/Images)
    match /offering_templates/{allPaths=**} {
      // Internal users can read these templates
      allow read: if request.auth != null;
      
      // Only HRD and Super Admins can manage these.
      allow write: if request.auth != null && (
        exists(/databases/(default)/documents/roles_admin/$(request.auth.uid)) ||
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'hrd' ||
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'super-admin'
      );
    }

    // Rules for job offerings PDFs
    match /offerings/{applicationId}/{allPaths=**} {
      // HRD can upload, everyone can read
      allow read;
      allow write: if request.auth != null && (
        exists(/databases/(default)/documents/roles_admin/$(request.auth.uid)) ||
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'hrd' ||
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'super-admin'
      );
    }
  }
}
